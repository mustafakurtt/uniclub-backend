# Production stack (docker-compose.prod.yml) ortam değişkenleri.
# Kopyala:  cp .env.prod.example .env.prod   ve değerleri doldur.
# .env.prod GİT'E GİRMEZ.

# ─── Ağ ────────────────────────────────────────────────────────
# BIND_ADDR bir GÜVENLİK ayarıdır: servislerin hangi arayüzde dinleyeceği.
#   127.0.0.1  → yalnızca bu makine (okul/kafe gibi paylaşımlı ağlarda ŞART)
#   10.0.0.5   → ev ağındaki diğer cihazlar da erişsin (makinenin sabit LAN IP'si)
BIND_ADDR=127.0.0.1

# ─── Uygulama ──────────────────────────────────────────────────
# Trafik normalde Caddy'den (:443) gelir. Bu port hata ayıklama içindir.
APP_PORT=8080
# Mailin içindeki doğrulama linki bu adresle üretilir → proxy'nin adresi olmalı.
APP_URL="https://uniclub.test"

# Güçlü ve DEV'DEKİNDEN FARKLI bir anahtar: openssl rand -base64 48
# Aynı secret paylaşılırsa dev'de üretilen token prod'da da geçerli olur.
JWT_SECRET="change-me"

# ─── Veritabanı ────────────────────────────────────────────────
# Bu container compose ağının içinde yaşar; portu dışarı açılmaz.
POSTGRES_USER="uniclub"
POSTGRES_PASSWORD="change-me"
POSTGRES_DB="uniclub"

# ─── Mail ──────────────────────────────────────────────────────
# Yerel prod simülasyonunda Mailpit:  --profile localmail
#   SMTP_HOST=mailpit  SMTP_PORT=1025  SMTP_SECURE=false
# Gerçek sunucuda: sağlayıcının bilgileri.
SMTP_HOST="mailpit"
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="UniClub <no-reply@uniclub.local>"
MAILPIT_UI_PORT=8026

# Caddy reverse proxy'si arkasındayız (docker-compose.proxy.yml), o yüzden
# X-Forwarded-For gerçek istemciyi taşır. Proxy YOKKEN true yapmak, istemcinin
# kendi IP'sini uydurmasına ve rate limit'i atlatmasına izin verir.
TRUST_PROXY=true

# IMAGE_TAG'i buraya YAZMA. deploy-local.sh onu commit SHA'sından üretir;
# sabitlersen her deploy aynı etiketi alır ve rollback yapacak imaj kalmaz.
