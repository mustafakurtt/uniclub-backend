{
  "name": "uniclub-backend",
  "version": "1.0.0",
  "description": "UniClub — multi-tenant SaaS backend for university club management. Bun, Hono, Drizzle, PostgreSQL, Redis/BullMQ.",
  "license": "MIT",
  "author": "Mustafa Kurt",
  "repository": {
    "type": "git",
    "url": "https://github.com/mustafakurtt/uniclub-backend.git"
  },
  "keywords": [
    "bun",
    "hono",
    "drizzle-orm",
    "postgresql",
    "multi-tenant",
    "rbac",
    "saas",
    "backend"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "bun run src/db/seed.ts",
    "db:sync-permissions": "bun run src/db/sync-permissions.ts",
    "db:backup": "bash scripts/db-backup.sh",
    "db:restore": "bash scripts/db-restore.sh",
    "deploy:agent": "bash scripts/deploy-agent.sh",
    "deploy:logs": "tail -f -n 50 ~/uniclub-prod/logs/deploy-agent.log",
    "prod:ps": "docker compose -p uniclub-prod -f docker-compose.prod.yml ps",
    "prod:logs": "docker logs -f --tail 50 uniclub_prod_app",
    "proxy:up": "docker compose -p uniclub-proxy -f docker-compose.proxy.yml --env-file .env.prod up -d",
    "proxy:down": "docker compose -p uniclub-proxy -f docker-compose.proxy.yml down",
    "proxy:logs": "docker compose -p uniclub-proxy -f docker-compose.proxy.yml logs -f",
    "db:reset": "drizzle-kit drop && bun run db:generate && bun run db:migrate && bun run db:seed"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "@types/node": "^26.1.0",
    "bullmq": "^5.79.2",
    "drizzle-orm": "^1.0.0-rc.4",
    "hono": "^4.12.27",
    "ioredis": "^5.11.1",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "pino": "^9.6.0",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^1.0.0-rc.4",
    "pino-pretty": "^13.0.0",
    "typescript": "^5.7.0"
  }
}
