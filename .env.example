# ─── Application ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# LOG_LEVEL=debug            # optional; defaults by NODE_ENV (dev: debug, prod: info)
# LOG_FILE=./logs/app.log   # optional; also write raw JSON here so the Vector log stack can tail it.
                            # Default (unset): stdout only. See docs/LOGLAMA.md.

# ─── Database (matches docker-compose) ─────────────────────────
DATABASE_URL="postgres://uniclub:uniclub_dev@localhost:5432/uniclub"

# ─── Redis (mail queue, RBAC cache, rate-limit, pub/sub) ───────
REDIS_URL="redis://localhost:6379"

# ─── Auth ──────────────────────────────────────────────────────
# Generate a strong secret, e.g.: openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-secret"

# ─── Email verification ────────────────────────────────────────
# Locally handled by Mailpit (docker-compose). Inbox: http://localhost:8025
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_SECURE=false
# SMTP_USER / SMTP_PASS: not needed by Mailpit; fill in for a real provider.
# SMTP_USER=""
# SMTP_PASS=""
MAIL_FROM="UniClub <no-reply@uniclub.local>"

# Base URL used inside the verification email link.
APP_URL="http://localhost:3000"

# ─── Rate limiting ─────────────────────────────────────────────
# RATE_LIMIT_DISABLED: test/CI only. NEVER true in production.
RATE_LIMIT_DISABLED=false
# TRUST_PROXY: set true only behind a reverse proxy (nginx/Cloudflare).
# Setting true without a proxy allows client X-Forwarded-For spoofing.
TRUST_PROXY=false

# ─── Security / HTTP limits ────────────────────────────────────
# CORS_ORIGINS: comma-separated allowlist. Unset = allow all (*) — fine for dev,
# but MUST be set in production. e.g. CORS_ORIGINS=https://app.example.com
# CORS_ORIGINS=
# MAX_BODY_BYTES: request body size cap (413 if exceeded). Default 1 MiB.
# MAX_BODY_BYTES=1048576

# ─── Web Push (VAPID) ──────────────────────────────────────────
# Optional. Both keys unset → web push disabled (WebSocket unaffected).
# Generate: bunx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@uniclub.local
